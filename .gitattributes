# Normalize line endings so contributors on any OS get clean, consistent diffs.
# Text files are stored as LF in the repo; Windows-only scripts keep CRLF.
* text=auto eol=lf

# Windows batch / PowerShell scripts must stay CRLF to run correctly.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Explicit text types (helps GitHub language stats + diffs)
*.py   text eol=lf
*.sh   text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.html text eol=lf
*.json text eol=lf
*.txt  text eol=lf

# Binary assets — never touch EOL or try to diff
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
