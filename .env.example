# Copy to ".env" in this folder and fill in values. Never commit ".env" (it is gitignored).

# -- LLM keys (at least one required) --
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# -- API / session --
AGENT_API_KEY=
ORYNN_API_KEY=
ORYNN_PORT=
ORYNN_WORKSPACE=
SESSION_TTL_SECONDS=
SESSION_COOKIE_SECURE=

# -- CORS --
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# -- Agent tuning (optional) --
APPROVAL_WAIT_TIMEOUT_SECONDS=
PERMISSION_WAIT_TIMEOUT_SECONDS=
ORYNN_MAX_ACTIVE_TASKS=
ORYNN_MAX_PERSISTED_TASKS=
AGENT_MAX_STEPS=
BROWSER_MAX_STEPS=
DESKTOP_MAX_STEPS=
# Desktop control defaults to the FREE UIA tier. For rock-solid reliability on
# long multi-step desktop tasks (chained actions, big forms), opt in to a
# stronger model here - free stays the default if left blank. Examples:
#   DESKTOP_MODEL=claude-3-5-sonnet-20241022        (needs ANTHROPIC_API_KEY)
#   DESKTOP_MODEL=gpt-4o                              (needs OPENAI_API_KEY)
#   DESKTOP_MODEL=openrouter/openai/gpt-oss-120b:free (still free, just bigger)
DESKTOP_MODEL=

# -- Browser / memory --
# BROWSER_HEADED=1
# USE_CHROMA=1

# -- Discord (pip install discord.py; Message Content Intent in portal) --
# Remote integrations are disabled unless at least one allowlist is set.
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_ALLOWED_GUILD_IDS=

# -- Telegram (pip install python-telegram-bot) --
# Remote integrations are disabled unless at least one allowlist is set.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=

# -- Optional MCP-related keys --
EXA_API_KEY=
FIGMA_ACCESS_TOKEN=
TAVILY_API_KEY=
SLACK_BOT_TOKEN=
ORYNN_MCP_CONFIG=

# Legacy AI_COMPUTER_* variables are still accepted for existing local installs.
